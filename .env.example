# Titan Grove Configuration

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=localhost

# Database Configuration
DB_TYPE=sqlite
# DB_TYPE=postgresql
# DB_TYPE=mysql
# DB_TYPE=mongodb

# For PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=titan_grove
# DB_USER=postgres
# DB_PASSWORD=password

# For MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=titan_grove
# DB_USER=root
# DB_PASSWORD=password

# For SQLite (default)
DB_NAME=./data/titan_grove.db

# For MongoDB
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=titan_grove

# Alternative: Use connection URL
# DATABASE_URL=postgresql://user:password@localhost:5432/titan_grove
# DATABASE_URL=mysql://user:password@localhost:3306/titan_grove
# DATABASE_URL=mongodb://localhost:27017/titan_grove

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please

# Caching (Redis)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Analytics
ANALYTICS_ENABLED=false
# ELASTICSEARCH_HOST=localhost
# ELASTICSEARCH_PORT=9200

# Clustering
CLUSTER_ENABLED=false
# CLUSTER_WORKERS=4

# Logging
LOG_LEVEL=info
LOG_FORMAT=simple