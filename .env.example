# Titan Grove Configuration

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=localhost

# Database Configuration
DB_TYPE=sqlite
# DB_TYPE=postgresql
# DB_TYPE=mysql
# DB_TYPE=mongodb

# For PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=titan_grove
# DB_USER=postgres
# DB_PASSWORD=password

# For MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=titan_grove
# DB_USER=root
# DB_PASSWORD=password

# For SQLite (default)
DB_NAME=./data/titan_grove.db

# For MongoDB
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=titan_grove

# Alternative: Use connection URL
# DATABASE_URL=postgresql://user:password@localhost:5432/titan_grove
# DATABASE_URL=mysql://user:password@localhost:3306/titan_grove
# DATABASE_URL=mongodb://localhost:27017/titan_grove

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please

# Caching (Redis)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Analytics
ANALYTICS_ENABLED=false
# ELASTICSEARCH_HOST=localhost
# ELASTICSEARCH_PORT=9200

# Clustering
CLUSTER_ENABLED=false
# CLUSTER_WORKERS=4

# Logging
LOG_LEVEL=info
LOG_FORMAT=simple

# ================================
# PROJECT MANAGEMENT CONFIGURATION
# ================================

# Project Billing Settings
PROJ_DEFAULT_HOURLY_RATE=125
PROJ_STANDARD_TAX_RATE=0.08
PROJ_PAYMENT_TERMS_DAYS=30

# Project Financial Defaults
PROJ_DEFAULT_LABOR_RATE=150
PROJ_DEFAULT_MATERIAL_COST=5000
PROJ_OVERHEAD_RATIO=0.15
PROJ_PROFIT_MARGIN_TARGET=0.29

# Project Health Score Thresholds
PROJ_SCHEDULE_PERFORMANCE_TARGET=0.95
PROJ_COST_PERFORMANCE_TARGET=1.02
PROJ_SCOPE_COMPLETION_TARGET=0.65
PROJ_QUALITY_METRICS_TARGET=0.92
PROJ_RISK_SCORE_THRESHOLD=0.15
PROJ_TEAM_SATISFACTION_TARGET=0.88

# Project Resource Management
PROJ_UTILIZATION_TARGET=78
PROJ_OVERALLOCATION_THRESHOLD=0.95
PROJ_CAPACITY_BUFFER_RATIO=0.15

# Project Reporting Defaults
PROJ_FORECAST_CONFIDENCE_DEFAULT=0.85
PROJ_REPORTING_PERIOD_DAYS=45
PROJ_SCHEDULE_VARIANCE_DAYS=5
PROJ_BUDGET_VARIANCE_AMOUNT=7000