# Titan Grove Production Business Configuration
# Production-grade settings with optimized parameters

# ================================
# Database Configuration
# ================================
DB_TYPE=postgresql
DB_HOST=prod-postgres-cluster.company.com
DB_PORT=5432
DB_NAME=titan_grove_prod
DB_USER=titan_prod_user
DB_PASSWORD=${SECURE_DB_PASSWORD}
# SSL required in production
DATABASE_SSL=true

# ================================
# Server Configuration
# ================================
PORT=3000
HOST=0.0.0.0
JWT_SECRET=${SECURE_JWT_SECRET}

# ================================
# Redis Configuration
# ================================
REDIS_HOST=prod-redis-cluster.company.com
REDIS_PORT=6379
REDIS_PASSWORD=${SECURE_REDIS_PASSWORD}

# ================================
# Configure-to-Order Business Settings (Production Values)
# ================================

# Product Configuration Defaults - Optimized for production pricing
CTO_DEFAULT_BASE_PRICE=1500
CTO_DEFAULT_BASE_COST=975
CTO_DEFAULT_COST_RATIO=0.65
CTO_DEFAULT_LEAD_TIME_BASE=12

# Manufacturing Complexity Thresholds - Refined for production scale
CTO_STANDARD_COMPLEXITY_MAX_OPTIONS=5
CTO_COMPLEX_COMPLEXITY_MAX_OPTIONS=12

# Engineering Configuration - Premium rates for production
CTO_ENGINEERING_HOURLY_RATE=175
CTO_DEFAULT_ENGINEERING_DURATION=12
CTO_PROTOTYPE_DEVELOPMENT_DURATION=8
CTO_PRODUCTION_PLANNING_DURATION=4
CTO_BASE_PROJECT_TIMELINE=25
CTO_DEFAULT_SAMPLE_LEAD_TIME=5

# ================================
# Capital Asset Management Settings (Production Values)
# ================================

# ROI Analysis Scenarios - Conservative production estimates
CAM_ROI_BASE_CASE_PROBABILITY=55
CAM_ROI_OPTIMISTIC_PROBABILITY=25
CAM_ROI_PESSIMISTIC_PROBABILITY=20

# Budget Allocation Recommendations - Production optimized
CAM_BUDGET_PRODUCTION_EQUIPMENT=45
CAM_BUDGET_REGULATORY_COMPLIANCE=25
CAM_BUDGET_DIGITAL_TRANSFORMATION=20

# Default Analysis Parameters - Production financial assumptions
CAM_DEFAULT_DISCOUNT_RATE=0.10
CAM_DEFAULT_ANALYSIS_TIME_HORIZON=7

# ================================
# Manufacturing Settings (Production Values)
# ================================

# BOM Management - Production complexity
MFG_DEFAULT_BOM_COMPLEXITY=0.70

# Production Lead Times - Optimized for scale
MFG_STANDARD_PRODUCTION_LEAD_TIME=5
MFG_CUSTOM_PRODUCTION_LEAD_TIME=15

# Cost Management Variance Thresholds - Tighter production controls
MFG_MATERIAL_COST_VARIANCE_THRESHOLD=8
MFG_LABOR_COST_VARIANCE_THRESHOLD=12

# ================================
# Message Queue Settings (Production Scale)
# ================================

# Clustering - Production scale
MQ_CLUSTER_WORKERS=8
MQ_CLUSTER_CONCURRENCY=20

# Job Configuration - Production reliability
MQ_JOB_REMOVE_ON_COMPLETE=200
MQ_JOB_REMOVE_ON_FAIL=100
MQ_JOB_ATTEMPTS=5
MQ_JOB_BACKOFF_DELAY=3000

# Monitoring Thresholds - Production alerting
MQ_QUEUE_DEPTH_THRESHOLD=2000
MQ_PROCESSING_TIME_THRESHOLD=45000
MQ_ERROR_RATE_THRESHOLD=0.05

# Retention Settings - Production data retention
MQ_METRICS_RETENTION_DAYS=30
MQ_DLQ_MAX_RETRIES=10
MQ_DLQ_RETENTION_DAYS=90

# ================================
# Project Management Settings (Production Values)
# ================================

# Performance Thresholds - Tighter production controls
PROJ_BUDGET_VARIANCE_ALERT=0.08
PROJ_SCHEDULE_VARIANCE_ALERT=0.12

# Billing Rates - Premium production rates
PROJ_DEFAULT_HOURLY_RATE=150
PROJ_OVERTIME_MULTIPLIER=1.5

# ================================
# Order Analytics Settings (Production Values)
# ================================

# Risk Analysis - Production risk management
OA_DEFAULT_CREDIT_UTILIZATION=0.70

# Performance Thresholds - High production standards
OA_SCOPE_COMPLETION_THRESHOLD=0.75
OA_QUALITY_SCORE_THRESHOLD=0.90
OA_DELIVERY_PERFORMANCE_THRESHOLD=0.95

# ================================
# Analytics Configuration (Production)
# ================================
ANALYTICS_ENABLED=true
ELASTICSEARCH_HOST=prod-elasticsearch-cluster.company.com
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=titan_analytics_user
ELASTICSEARCH_PASSWORD=${SECURE_ELASTICSEARCH_PASSWORD}

# ================================
# Cluster Configuration (Production)
# ================================
CLUSTER_ENABLED=true
CLUSTER_WORKERS=16

# ================================
# Security Configuration (Production)
# ================================
HELMET_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ================================
# Monitoring and Observability (Production)
# ================================
MONITORING_ENABLED=true
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
APM_ENABLED=true
TRACING_ENABLED=true

# Performance monitoring
PERFORMANCE_MONITORING_ENABLED=true
SLOW_QUERY_THRESHOLD=5000
MEMORY_USAGE_THRESHOLD=0.80
CPU_USAGE_THRESHOLD=0.75

# Alerting thresholds
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_RESPONSE_TIME_THRESHOLD=5000
ALERT_THROUGHPUT_MIN_THRESHOLD=100

# ================================
# Manufacturing Configuration (Production)
# ================================

# Industry 4.0 IoT Sensor Configuration - Production optimized latencies
MFG_INDUSTRY40_DEFAULT_SENSOR_LATENCY=100
MFG_INDUSTRY40_TEMPERATURE_SENSOR_LATENCY=10
MFG_INDUSTRY40_VIBRATION_SENSOR_LATENCY=15
MFG_INDUSTRY40_PRESSURE_SENSOR_LATENCY=5

# Supply Chain Integration Data Volumes (KB)
MFG_INTEGRATION_DEMAND_PLANNING_KB=1800
MFG_INTEGRATION_PRODUCTION_DATA_KB=3200
MFG_INTEGRATION_INVENTORY_DATA_KB=400
MFG_INTEGRATION_MAINTENANCE_DATA_KB=200

# Supply Chain Integration Latencies (milliseconds) - Production SLA
MFG_INTEGRATION_DEMAND_PLANNING_MS=100
MFG_INTEGRATION_PRODUCTION_DATA_MS=8
MFG_INTEGRATION_INVENTORY_DATA_MS=150
MFG_INTEGRATION_MAINTENANCE_DATA_MS=25

# Supply Chain Integration Reliability (percentage) - Production targets
MFG_INTEGRATION_DEMAND_PLANNING_RELIABILITY=99.5
MFG_INTEGRATION_PRODUCTION_DATA_RELIABILITY=99.7
MFG_INTEGRATION_INVENTORY_DATA_RELIABILITY=99.8
MFG_INTEGRATION_MAINTENANCE_DATA_RELIABILITY=98.5

# Migration Business Value - Updated for production deployment
MFG_INTEGRATION_IMMEDIATE_VALUE=3500000
MFG_INTEGRATION_STRATEGIC_VALUE=12000000
MFG_INTEGRATION_FUTURE_VALUE=20000000

# ================================
# Warehouse Management Configuration (Production)
# ================================

# Operating Hours - Production warehouse schedule
WM_WEEKDAY_START_TIME=06:00
WM_WEEKDAY_END_TIME=18:00
WM_WEEKDAY_TIMEZONE=EST
WM_SATURDAY_START_TIME=08:00
WM_SATURDAY_END_TIME=14:00
WM_SATURDAY_TIMEZONE=EST

# Shift Configuration - Production staffing levels
WM_DAY_SHIFT_START_TIME=06:00
WM_DAY_SHIFT_END_TIME=14:00
WM_DAY_SHIFT_STAFF_COUNT=45

WM_EVENING_SHIFT_START_TIME=14:00
WM_EVENING_SHIFT_END_TIME=22:00
WM_EVENING_SHIFT_STAFF_COUNT=25

WM_NIGHT_SHIFT_START_TIME=22:00
WM_NIGHT_SHIFT_END_TIME=06:00
WM_NIGHT_SHIFT_STAFF_COUNT=12

# Storage Area Configuration - Production facility dimensions
WM_BULK_STORAGE_LENGTH=250
WM_BULK_STORAGE_WIDTH=120
WM_BULK_STORAGE_HEIGHT=35
WM_BULK_TOTAL_POSITIONS=1500
WM_BULK_UTILIZATION_RATE=85
WM_BULK_TURNOVER_RATE=18

WM_RACK_STORAGE_LENGTH=350
WM_RACK_STORAGE_WIDTH=180
WM_RACK_STORAGE_HEIGHT=28
WM_RACK_TOTAL_POSITIONS=2500
WM_RACK_UTILIZATION_RATE=80
WM_RACK_TURNOVER_RATE=30

# Dock Door Configuration - Production facility scale
WM_DOCK_DOOR_COUNT=16
WM_DOCK_DOOR_HEIGHT=10
WM_DOCK_DOOR_WIDTH=9
WM_DOCK_LEVELING_DEFAULT=true