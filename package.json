{
  "name": "titan-grove",
  "type": "commonjs",
  "version": "1.0.0",
  "description": "Enterprise SOA Project - Modern Oracle EBS 12 competitor with integrated microservices",
  "private": true,
  "workspaces": [
    "frontend/web-portal",
    "frontend/admin-console", 
    "frontend/shared/ui-components",
    "backend/services/user-service",
    "backend/services/financial-service",
    "backend/services/crm-service", 
    "backend/services/analytics-service",
    "backend/shared/node-common"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "titan": "./bin/titan.js",
    "titan-db": "./bin/titan-db.js",
    "titan-server": "./bin/titan-server.js"
  },
  "scripts": {
    "build": "npm run build:legacy && npm run build:services",
    "build:legacy": "npm run build:native && npm run build:ui && tsc",
    "build:services": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm run build -w frontend/web-portal && npm run build -w frontend/admin-console",
    "build:backend": "npm run build -w backend/services/user-service && npm run build -w backend/services/financial-service && npm run build -w backend/services/crm-service && npm run build -w backend/services/analytics-service",
    "build:rust": "cd backend/services/order-service && cargo build --release && cd ../payment-service && cargo build --release",
    "build:native": "napi build --platform --release --js native.js --dts native.d.ts",
    "build:native:debug": "napi build --platform --js native.js --dts native.d.ts",
    "build:watch": "tsc --watch",
    "build:ui": "vite build",
    "dev": "npm run dev:legacy",
    "dev:legacy": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:services": "concurrently \"npm run dev -w backend/services/user-service\" \"npm run dev -w backend/services/financial-service\" \"npm run dev -w backend/services/crm-service\" \"npm run dev -w backend/services/analytics-service\" \"npm run dev -w frontend/web-portal\"",
    "dev:ui": "vite",
    "dev:production": "ts-node-dev --respawn --transpile-only src/production-server.ts",
    "start": "node dist/production-server.js",
    "start:dev": "npm run build && npm start",
    "start:services": "docker-compose -f docker-compose.dev.yml up",
    "preview:ui": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:services": "npm test -w backend/services/user-service && npm test -w backend/services/financial-service && npm test -w backend/services/crm-service && npm test -w backend/services/analytics-service && cd backend/services/order-service && cargo test",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:dashboard": "cypress run --spec 'cypress/e2e/dashboard.cy.js'",
    "test:e2e:manufacturing": "cypress run --spec 'cypress/e2e/manufacturing.cy.js'",
    "test:e2e:financials": "cypress run --spec 'cypress/e2e/financials.cy.js'",
    "test:e2e:bi": "cypress run --spec 'cypress/e2e/business-intelligence.cy.js'",
    "test:e2e:setup": "cypress run --spec 'cypress/e2e/setup-wizard.cy.js'",
    "test:e2e:all-modules": "cypress run --spec 'cypress/e2e/all-modules.cy.js'",
    "test:e2e:integration": "cypress run --spec 'cypress/e2e/cross-module-integration.cy.js'",
    "lint": "eslint 'src/**/*.{js,ts}' --quiet --fix --config .eslintrc.js",
    "lint:check": "eslint 'src/**/*.{js,ts}' --quiet --config .eslintrc.js",
    "lint:services": "npm run lint -w backend/services/user-service && npm run lint -w backend/services/financial-service && npm run lint -w backend/services/crm-service && npm run lint -w backend/services/analytics-service",
    "format": "prettier --write 'src/**/*.{js,ts,json,md}'",
    "format:check": "prettier --check 'src/**/*.{js,ts,json,md}'",
    "docker:build": "docker build -t titan-grove .",
    "docker:run": "docker run -p 3000:3000 titan-grove",
    "docker:services": "docker-compose -f docker-compose.dev.yml build",
    "clean": "rm -rf dist target node_modules frontend/*/dist backend/*/dist",
    "clean:services": "rm -rf frontend/*/dist backend/services/*/dist backend/services/*/target",
    "benchmark": "node dist/tools/benchmark.js",
    "security:audit": "npm audit && npx audit-ci --config audit-ci.json"
  },
  "keywords": [
    "erp",
    "enterprise-business-suite",
    "oracle-ebs-12",
    "financial-management",
    "human-resources",
    "supply-chain",
    "customer-relationship-management",
    "project-management",
    "business-intelligence",
    "accounting",
    "payroll",
    "inventory",
    "crm",
    "business-applications",
    "enterprise-software"
  ],
  "author": "Titan Grove Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@carbon/icons-react": "^11.66.0",
    "@carbon/layout": "^11.40.0",
    "@carbon/react": "^1.90.0",
    "@carbon/styles": "^1.89.0",
    "@carbon/themes": "^11.59.0",
    "@carbon/type": "^11.46.0",
    "@elastic/elasticsearch": "^9.1.1",
    "@types/axios": "^0.9.36",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "agenda": "^5.0.0",
    "async": "^3.2.6",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "bluebird": "^3.7.2",
    "bull": "^4.16.5",
    "chalk": "^5.6.0",
    "cluster": "^0.7.7",
    "commander": "^14.0.0",
    "compression": "^1.8.1",
    "config": "^4.1.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dataloader": "^2.2.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "fastify": "^5.5.0",
    "graphql": "^16.11.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.7.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mongodb": "^6.19.0",
    "morgan": "^1.10.1",
    "mysql2": "^3.14.3",
    "node-cron": "^4.2.1",
    "node-forge": "^1.3.1",
    "pg": "^8.16.3",
    "pino": "^9.9.0",
    "playwright": "^1.55.0",
    "pm2": "^6.0.8",
    "ramda": "^0.31.3",
    "rate-limiter-flexible": "^7.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "redis": "^5.8.2",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.1",
    "uuid": "^11.1.0",
    "vite": "^7.1.4",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@jest/types": "^30.0.5",
    "@napi-rs/cli": "^2.18.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "audit-ci": "^7.1.0",
    "concurrently": "^8.2.0",
    "cypress": "^15.0.0",
    "eslint": "^9.34.0",
    "globals": "^16.4.0",
    "jest": "^30.1.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
