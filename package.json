{
  "name": "titan-grove",
  "version": "1.0.0",
  "description": "Enterprise Business Suite - Modern Oracle EBS 12 competitor with integrated business applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "titan": "./bin/titan.js",
    "titan-db": "./bin/titan-db.js",
    "titan-server": "./bin/titan-server.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'src/**/*.{js,ts}' --quiet --fix",
    "lint:check": "eslint 'src/**/*.{js,ts}' --quiet",
    "format": "prettier --write 'src/**/*.{js,ts,json,md}'",
    "format:check": "prettier --check 'src/**/*.{js,ts,json,md}'",
    "docker:build": "docker build -t titan-grove .",
    "docker:run": "docker run -p 3000:3000 titan-grove",
    "benchmark": "node dist/tools/benchmark.js",
    "security:audit": "npm audit && npx audit-ci --config audit-ci.json"
  },
  "keywords": [
    "erp",
    "enterprise-business-suite",
    "oracle-ebs-12",
    "financial-management",
    "human-resources",
    "supply-chain",
    "customer-relationship-management",
    "project-management",
    "business-intelligence",
    "accounting",
    "payroll",
    "inventory",
    "crm",
    "business-applications",
    "enterprise-software"
  ],
  "author": "Titan Grove Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.1.1",
    "agenda": "^5.0.0",
    "apollo-server-express": "^3.13.0",
    "async": "^3.2.6",
    "bcryptjs": "^3.0.2",
    "bluebird": "^3.7.2",
    "bull": "^4.16.5",
    "chalk": "^5.6.0",
    "cluster": "^0.7.7",
    "commander": "^14.0.0",
    "compression": "^1.8.1",
    "config": "^4.1.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dataloader": "^2.2.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "elasticsearch": "^16.7.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "fastify": "^5.5.0",
    "graphql": "^16.11.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.7.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mongodb": "^6.19.0",
    "morgan": "^1.10.1",
    "mysql2": "^3.14.3",
    "node-cron": "^4.2.1",
    "node-forge": "^1.3.1",
    "pg": "^8.16.3",
    "pino": "^9.9.0",
    "pm2": "^6.0.8",
    "ramda": "^0.31.3",
    "rate-limiter-flexible": "^7.2.0",
    "redis": "^5.8.2",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@jest/types": "^30.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.3.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "audit-ci": "^7.1.0",
    "eslint": "^9.34.0",
    "jest": "^30.1.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
