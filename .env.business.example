# Titan Grove Business Configuration Environment Variables
# Copy to .env and customize for your environment

# ================================
# Database Configuration
# ================================
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=titan_grove
DB_USER=titan_user
DB_PASSWORD=secure_password
DATABASE_URL=

# ================================
# Server Configuration
# ================================
PORT=3000
HOST=localhost
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ================================
# Redis Configuration
# ================================
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# ================================
# Configure-to-Order Business Settings
# ================================

# Product Configuration Defaults
CTO_DEFAULT_BASE_PRICE=1000
CTO_DEFAULT_BASE_COST=650
CTO_DEFAULT_COST_RATIO=0.65
CTO_DEFAULT_LEAD_TIME_BASE=14

# Manufacturing Complexity Thresholds
CTO_STANDARD_COMPLEXITY_MAX_OPTIONS=3
CTO_COMPLEX_COMPLEXITY_MAX_OPTIONS=8

# Engineering Configuration
CTO_ENGINEERING_HOURLY_RATE=150
CTO_DEFAULT_ENGINEERING_DURATION=15
CTO_PROTOTYPE_DEVELOPMENT_DURATION=10
CTO_PRODUCTION_PLANNING_DURATION=5
CTO_BASE_PROJECT_TIMELINE=30
CTO_DEFAULT_SAMPLE_LEAD_TIME=7

# ================================
# Capital Asset Management Settings
# ================================

# ROI Analysis Scenarios (percentages)
CAM_ROI_BASE_CASE_PROBABILITY=60
CAM_ROI_OPTIMISTIC_PROBABILITY=20
CAM_ROI_PESSIMISTIC_PROBABILITY=20

# Budget Allocation Recommendations (percentages)
CAM_BUDGET_PRODUCTION_EQUIPMENT=40
CAM_BUDGET_REGULATORY_COMPLIANCE=20
CAM_BUDGET_DIGITAL_TRANSFORMATION=15

# Default Analysis Parameters
CAM_DEFAULT_DISCOUNT_RATE=0.08
CAM_DEFAULT_ANALYSIS_TIME_HORIZON=5

# ================================
# Manufacturing Settings
# ================================

# BOM Management
MFG_DEFAULT_BOM_COMPLEXITY=0.65

# Production Lead Times (days)
MFG_STANDARD_PRODUCTION_LEAD_TIME=7
MFG_CUSTOM_PRODUCTION_LEAD_TIME=21

# Cost Management Variance Thresholds (percentages)
MFG_MATERIAL_COST_VARIANCE_THRESHOLD=10
MFG_LABOR_COST_VARIANCE_THRESHOLD=15

# ================================
# Message Queue Settings
# ================================

# Clustering
MQ_CLUSTER_WORKERS=4
MQ_CLUSTER_CONCURRENCY=10

# Job Configuration
MQ_JOB_REMOVE_ON_COMPLETE=100
MQ_JOB_REMOVE_ON_FAIL=50
MQ_JOB_ATTEMPTS=3
MQ_JOB_BACKOFF_DELAY=2000

# Monitoring Thresholds
MQ_QUEUE_DEPTH_THRESHOLD=1000
MQ_PROCESSING_TIME_THRESHOLD=30000
MQ_ERROR_RATE_THRESHOLD=0.1

# Retention Settings
MQ_METRICS_RETENTION_DAYS=7
MQ_DLQ_MAX_RETRIES=5
MQ_DLQ_RETENTION_DAYS=30

# ================================
# Project Management Settings
# ================================

# Performance Thresholds (percentages as decimals)
PROJ_BUDGET_VARIANCE_ALERT=0.1
PROJ_SCHEDULE_VARIANCE_ALERT=0.15

# Billing Rates
PROJ_DEFAULT_HOURLY_RATE=125
PROJ_OVERTIME_MULTIPLIER=1.5

# ================================
# Order Analytics Settings
# ================================

# Risk Analysis
OA_DEFAULT_CREDIT_UTILIZATION=0.65

# Performance Thresholds (ratios)
OA_SCOPE_COMPLETION_THRESHOLD=0.65
OA_QUALITY_SCORE_THRESHOLD=0.85
OA_DELIVERY_PERFORMANCE_THRESHOLD=0.90

# ================================
# Analytics Configuration
# ================================
ANALYTICS_ENABLED=false
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=

# ================================
# Cluster Configuration
# ================================
CLUSTER_ENABLED=false