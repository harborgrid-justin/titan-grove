# React UI Environment Configuration

# API Configuration
REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_API_TIMEOUT=30000
REACT_APP_API_RETRY_ATTEMPTS=3
REACT_APP_API_RETRY_DELAY=1000

# Application Configuration
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0
REACT_APP_BUILD_TIME=2024-01-01T00:00:00Z

# Feature Flags (for enterprise deployments)
REACT_APP_FEATURE_REAL_TIME_UPDATES=true
REACT_APP_FEATURE_ADVANCED_ANALYTICS=true
REACT_APP_FEATURE_AUDIT_TRAIL=true